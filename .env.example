# Copie para .env e preencha. O .env está no .gitignore e nunca deve ser commitado.

# --- Banco de dados ---
POSTGRES_USER=painel
POSTGRES_PASSWORD=trocar
POSTGRES_DB=atas

# Porta no HOST para acessar o Postgres de fora do compose (a 5432/5433 já estão
# em uso por outros projetos). A porta interna do container continua sendo 5432.
POSTGRES_HOST_PORT=5434

# Porta no HOST onde o painel fica acessível (http://localhost:APP_PORT).
APP_PORT=8501

# DATABASE_URL é usada quando você roda algo NO HOST (ex.: a carga inicial,
# scripts/load_csv_to_db.py). Use a mesma porta de POSTGRES_HOST_PORT acima.
# Dentro do docker-compose o app usa o host "db:5432" automaticamente (não mexa).
DATABASE_URL=postgresql+psycopg2://painel:trocar@localhost:5434/atas

# --- Bots ---
# Credenciais institucionais do portal eSJC/ADMC. NUNCA commitar valores reais.
PORTAL_CPF=
PORTAL_SENHA=
# Navegador invisível (true) para execução agendada; false para depurar vendo a tela.
BOT_HEADLESS=true
