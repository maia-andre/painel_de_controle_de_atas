# Copie para .env e preencha. O .env está no .gitignore e nunca deve ser commitado.

# --- Banco de dados ---
POSTGRES_USER=painel
POSTGRES_PASSWORD=trocar
POSTGRES_DB=atas
DATABASE_URL=postgresql+psycopg2://painel:trocar@localhost:5432/atas

# --- Credenciais institucionais do portal eSJC/ADMC (usadas pelos bots) ---
